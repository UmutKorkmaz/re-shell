/* ---------------------------------------------------------------------------
 * Terminal playground — deterministic, hard-coded command recordings.
 *
 * Each entry is a real CLI command paired with canned, realistic output. The
 * output is authored as token segments ({ t: text, c?: colorClass }) so the
 * vanilla-TS island can render the same markup it builds at runtime, and the
 * server can pre-render the FIRST command for a valid JS-off static state.
 * Nothing here executes — it is a recording.
 * ------------------------------------------------------------------------- */
type Seg = { t: string; c?: string };
type Line = Seg[];
type PlayCmd = {
  /** chip label (short) */
  label: string;
  /** command after the `re-shell` binary, e.g. "workspace summary --json" */
  cmd: string;
  /** colorized output lines */
  out: Line[];
};

const seg = (t: string, c?: string): Seg => (c ? { t, c } : { t });

