{
  "name": "@re-shell/mcp",
  "version": "0.1.0",
  "description": "Stdio MCP server exposing Re-Shell's read-only JSON commands as agent tools.",
  "license": "MIT",
  "author": "Umut Korkmaz",
  "type": "module",
  "keywords": [
    "re-shell",
    "mcp",
    "model-context-protocol",
    "cli",
    "agent-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/UmutKorkmaz/re-shell.git",
    "directory": "packages/mcp"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "re-shell-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@re-shell/contracts": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.46",
    "typescript": "^5.0.0",
    "vitest": "^0.34.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://umutkorkmaz.github.io/re-shell/",
  "bugs": {
    "url": "https://github.com/UmutKorkmaz/re-shell/issues"
  }
}
