/** Render one command (prompt line + output) to static HTML for SSR + JS-off. */
const renderPlay = (c: PlayCmd): string => {
  const escape = (s: string): string =>
    s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  const span = (s: Seg): string =>
    s.c ? `<span class="${s.c}">${escape(s.t)}</span>` : escape(s.t);
  const prompt = `<span class="lp-prompt">$</span> <span class="lp-cmd">re-shell ${escape(
    c.cmd
  )}</span>`;
  const body = c.out.map((line) => line.map(span).join('')).join('\n');
  return `${prompt}\n${body}`;
};

/** Serialize the deck for the client island (typed; no runtime DOM scraping). */
const PLAY_DATA = PLAYGROUND.map((c) => ({ cmd: c.cmd, out: c.out }));

/* ---------------------------------------------------------------------------
 * Stack-builder command composition — the SAME logic the island runs at
 * runtime, used here to pre-render the default static command block (JS-off).
 * ------------------------------------------------------------------------- */
type StackSel = { frontend: string; backend: string; infra: string[] };
const composeStack = (sel: StackSel): Line[] => {
  const lines: Line[] = [];
  const fe = stackFrontend.find((o) => o.id === sel.frontend);
  const be = stackBackend.find((o) => o.id === sel.backend);
  if (fe) {
    lines.push([
      seg('$ ', 'lp-prompt'),
      seg('re-shell create ', 'lp-cmd'),
      seg('web ', 'lp-cmd'),
      seg('--template ', 'lp-flag'),
      seg(fe.template, 'lp-str'),
    ]);
  }
  if (be) {
    lines.push([
      seg('$ ', 'lp-prompt'),
      seg('re-shell generate service ', 'lp-cmd'),
      seg('--template ', 'lp-flag'),
      seg(be.template, 'lp-str'),
    ]);
  }
  sel.infra.forEach((id) => {
    const inf = stackInfra.find((o) => o.id === id);
    if (inf) {
      lines.push([
        seg('$ ', 'lp-prompt'),
        seg(`re-shell ${inf.template} generate`, 'lp-cmd'),
      ]);
    }
  });
  if (lines.length === 0) {
    lines.push([seg('# pick a frontend or backend to compose a command', 'lp-mute')]);
  }
  return lines;
};
/** Render composed command lines to static HTML (SSR + JS-off). */
const renderStack = (sel: StackSel): string => {
  const escape = (s: string): string =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const span = (s: Seg): string =>
    s.c ? `<span class="${s.c}">${escape(s.t)}</span>` : escape(s.t);
  return composeStack(sel)
    .map((line) => line.map(span).join(''))
    .join('\n');
};
const STACK_DEFAULT_HTML = renderStack({
  frontend: STACK_DEFAULT.frontend,
  backend: STACK_DEFAULT.backend,
  infra: STACK_DEFAULT.infra,
});
/** Plain text of the default composed command(s) for the static copy button. */
const STACK_DEFAULT_COPY = composeStack({
  frontend: STACK_DEFAULT.frontend,
  backend: STACK_DEFAULT.backend,
  infra: STACK_DEFAULT.infra,
})
  .map((line) =>
    line
      .map((s) => s.t)
      .join('')
      .replace(/^\$ /, '')
  )
  .join('\n');

