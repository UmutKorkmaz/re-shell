    <script>
      // Theme toggle — writes the same storage key the docs read.
      const toggle = document.getElementById('lp-theme');
      const syncToggleAriaLabel = (): void => {
        if (!toggle) return;
        const isDark = document.documentElement.dataset.theme === 'dark';
        toggle.setAttribute('aria-label', isDark ? 'Switch to light theme' : 'Switch to dark theme');
        toggle.setAttribute('aria-pressed', isDark ? 'false' : 'true');
      };
      syncToggleAriaLabel();
      toggle?.addEventListener('click', () => {
        const root = document.documentElement;
        const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        try {
          localStorage.setItem('starlight-theme', next);
        } catch {}
        syncToggleAriaLabel();
      });

      // Copy buttons (install + any [data-copy]).
      document.querySelectorAll<HTMLButtonElement>('.lp-copy').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const text = btn.dataset.copy ?? '';
          try {
            await navigator.clipboard.writeText(text);
            btn.dataset.copied = 'true';
            setTimeout(() => (btn.dataset.copied = 'false'), 1600);
          } catch {
            /* clipboard blocked — no-op */
          }
        });
      });

      // Scroll reveal (progressive enhancement; reduced-motion handled in CSS).
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

      // ===== Browser-hero tabbed dashboard (vanilla TS island) =====
      (() => {
        const tablist = document.querySelector<HTMLElement>('.lp-tabs');
        if (!tablist) return;
        const tabs = Array.from(
          tablist.querySelectorAll<HTMLButtonElement>('[role="tab"]')
        );
        const tabEl = document.getElementById('lp-browser-tab');
        if (tabs.length === 0) return;

        // Mark JS as available so panels can cross-fade rather than swap.
        tablist.closest('.lp-browser')?.setAttribute('data-enhanced', 'true');

        const panelFor = (tab: HTMLButtonElement): HTMLElement | null => {
          const id = tab.getAttribute('aria-controls');
          return id ? document.getElementById(id) : null;
        };

        // Lower-cased label for the chrome tab per view (e.g. "graph").
        const tabLabel = (tab: HTMLButtonElement): string =>
          (tab.textContent ?? '').trim().toLowerCase();

        let auto = 0;
        const stopAuto = (): void => {
          if (auto) {
            window.clearInterval(auto);
            auto = 0;
          }
        };

        const selectTab = (tab: HTMLButtonElement, focus = true): void => {
          tabs.forEach((t) => {
            const selected = t === tab;
            t.setAttribute('aria-selected', selected ? 'true' : 'false');
            t.tabIndex = selected ? 0 : -1;
            const panel = panelFor(t);
            if (panel) {
              panel.hidden = !selected;
              if (selected) {
                // re-trigger the enter transition (no-op under reduced-motion CSS)
                panel.classList.remove('is-shown');
                // force reflow so the animation restarts
                void panel.offsetWidth;
                panel.classList.add('is-shown');
              }
            }
          });
          if (tabEl) tabEl.textContent = `Re-Shell — ${tabLabel(tab)}`;
          if (focus) tab.focus();
        };

        tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            stopAuto();
            selectTab(tab, false);
          });
          tab.addEventListener('keydown', (ev: KeyboardEvent) => {
            const idx = tabs.indexOf(tab);
            let next = -1;
            if (ev.key === 'ArrowRight') next = (idx + 1) % tabs.length;
            else if (ev.key === 'ArrowLeft')
              next = (idx - 1 + tabs.length) % tabs.length;
            else if (ev.key === 'Home') next = 0;
            else if (ev.key === 'End') next = tabs.length - 1;
            if (next !== -1) {
              ev.preventDefault();
              stopAuto();
              selectTab(tabs[next]);
            }
          });
        });

        // Mark the initial panel as shown for the enter transition.
        const initial = tabs.find((t) => t.getAttribute('aria-selected') === 'true');
        const initialPanel = initial ? panelFor(initial) : null;
        initialPanel?.classList.add('is-shown');

        // Ambient auto-advance (8s); stops permanently on first interaction,
        // and never runs under reduced-motion.
        if (!reduce.matches) {
          auto = window.setInterval(() => {
            const cur = tabs.findIndex(
              (t) => t.getAttribute('aria-selected') === 'true'
            );
            selectTab(tabs[(cur + 1) % tabs.length], false);
          }, 8000);
          ['pointerdown', 'keydown', 'focusin'].forEach((evt) =>
            tablist.addEventListener(evt, stopAuto, { once: true })
          );
        }
      })();
      // ===== Terminal playground (vanilla TS island) =====
      (() => {
        type Seg = { t: string; c?: string };
        type PlayCmd = { cmd: string; out: Seg[][] };

        const root = document.getElementById('lp-play');
        const screen = document.getElementById('lp-play-screen');
        const dataEl = document.getElementById('lp-play-data');
        if (!root || !screen || !dataEl) return;

        let deck: PlayCmd[] = [];
        try {
          deck = JSON.parse(dataEl.textContent ?? '[]') as PlayCmd[];
        } catch {
          return;
        }
        if (deck.length === 0) return;

        const chips = Array.from(
          root.querySelectorAll<HTMLButtonElement>('.lp-play__chip')
        );
        const fill = document.getElementById('lp-play-fill');
        const countEl = document.getElementById('lp-play-n');
        const reward = document.getElementById('lp-play-reward');
        const title = document.getElementById('lp-play-title');
        const copyBtn = document.getElementById(
          'lp-play-copy'
        ) as HTMLButtonElement | null;
        const total = deck.length;

        // ---- exploration state (memory + best-effort sessionStorage) ----
        const STORE_KEY = 're-shell:playground:explored';
        const explored = new Set<number>();
        try {
          const raw = sessionStorage.getItem(STORE_KEY);
          if (raw) {
            (JSON.parse(raw) as number[]).forEach((n) => {
              if (n >= 0 && n < total) explored.add(n);
            });
          }
        } catch {
          /* storage blocked — memory only */
        }
        const persist = (): void => {
          try {
            sessionStorage.setItem(STORE_KEY, JSON.stringify([...explored]));
          } catch {
            /* no-op */
          }
        };

        const syncProgress = (): void => {
          const n = explored.size;
          if (countEl) countEl.textContent = String(n);
          if (fill) fill.style.width = `${(n / total) * 100}%`;
          if (reward) {
            const done = n >= total;
            reward.hidden = !done;
            if (done) root.setAttribute('data-complete', 'true');
          }
        };

        const markExplored = (i: number, chip: HTMLButtonElement): void => {
          const fresh = !explored.has(i);
          explored.add(i);
          chip.setAttribute('aria-pressed', 'true');
          chip.classList.add('is-explored');
          if (fresh) {
            persist();
            syncProgress();
          }
        };

        // ---- DOM helpers ----
        const promptHTML = (cmd: string): string => {
          const esc = (s: string): string =>
            s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          return `<span class="lp-prompt">$</span> <span class="lp-cmd">re-shell ${esc(
            cmd
          )}</span>`;
        };
        const appendSeg = (s: Seg): void => {
          const node = s.c
            ? document.createElement('span')
            : document.createTextNode(s.t);
          if (s.c && node instanceof HTMLElement) {
            node.className = s.c;
            node.textContent = s.t;
          }
          screen.appendChild(node);
        };
        const renderOutput = (out: Seg[][]): void => {
          out.forEach((line, li) => {
            if (li > 0) screen.appendChild(document.createTextNode('\n'));
            line.forEach(appendSeg);
          });
        };

        // ---- typewriter ----
        const reduceMo = window.matchMedia('(prefers-reduced-motion: reduce)');
        let runToken = 0;
        const sleep = (ms: number): Promise<void> =>
          new Promise((r) => window.setTimeout(r, ms));

        const showInstant = (cmd: PlayCmd): void => {
          screen.innerHTML = promptHTML(cmd.cmd);
          screen.appendChild(document.createTextNode('\n'));
          renderOutput(cmd.out);
        };

        const typeAndReveal = async (cmd: PlayCmd, idx: number): Promise<void> => {
          const token = ++runToken;
          screen.innerHTML = '';
          const prompt = document.createElement('span');
          prompt.innerHTML = '<span class="lp-prompt">$</span> ';
          screen.appendChild(prompt);
          const typed = document.createElement('span');
          typed.className = 'lp-cmd';
          screen.appendChild(typed);
          const caret = document.createElement('span');
          caret.className = 'lp-play__caret';
          caret.setAttribute('aria-hidden', 'true');
          screen.appendChild(caret);

          const full = `re-shell ${cmd.cmd}`;
          for (let i = 0; i < full.length; i += 1) {
            if (token !== runToken) return; // superseded by a newer run
            typed.textContent = full.slice(0, i + 1);
            await sleep(28);
          }
          if (token !== runToken) return;
          caret.remove();
          screen.appendChild(document.createTextNode('\n'));
          await sleep(160);
          if (token !== runToken) return;
          renderOutput(cmd.out);
        };

        const run = (i: number, chip: HTMLButtonElement): void => {
          const cmd = deck[i];
          if (!cmd) return;
          if (title) title.textContent = `re-shell ${cmd.cmd}`;
          if (copyBtn) {
            copyBtn.hidden = false;
            copyBtn.dataset.copy = `re-shell ${cmd.cmd}`;
            copyBtn.dataset.copied = 'false';
          }
          chips.forEach((c) =>
            c.setAttribute('aria-current', c === chip ? 'true' : 'false')
          );
          if (reduceMo.matches) {
            runToken += 1; // cancel any in-flight typing
            showInstant(cmd);
          } else {
            void typeAndReveal(cmd, i);
          }
          markExplored(i, chip);
        };

        chips.forEach((chip) => {
          const i = Number(chip.dataset.cmd);
          chip.addEventListener('click', () => run(i, chip));
        });

        // copy current command
        copyBtn?.addEventListener('click', async () => {
          const text = copyBtn.dataset.copy ?? '';
          try {
            await navigator.clipboard.writeText(text);
            copyBtn.dataset.copied = 'true';
            window.setTimeout(() => (copyBtn.dataset.copied = 'false'), 1600);
          } catch {
            /* clipboard blocked — no-op */
          }
        });

        // restore prior exploration state for chips + meter
        explored.forEach((i) => {
          const chip = chips.find((c) => Number(c.dataset.cmd) === i);
          if (chip) {
            chip.setAttribute('aria-pressed', 'true');
            chip.classList.add('is-explored');
          }
        });
        syncProgress();

        // autoplay the first command once, when scrolled into view (reduced-
        // motion-safe: it still reveals output instantly). Stops after firing.
        let autoplayed = false;
        const autoplay = (): void => {
          if (autoplayed) return;
          autoplayed = true;
          run(0, chips[0]);
        };
        if (!('IntersectionObserver' in window)) {
          autoplay();
        } else {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (e.isIntersecting) {
                  autoplay();
                  io.disconnect();
                }
              });
            },
            { threshold: 0.4 }
          );
          io.observe(root);
        }
      })();

      // ===== Count-up stats (vanilla TS island) =====
      (() => {
        const strip = document.getElementById('lp-stats');
        if (!strip) return;
        const nums = Array.from(
          strip.querySelectorAll<HTMLElement>('.lp-stat__num')
        );
        if (nums.length === 0) return;

        // Final static values are already rendered server-side. Under reduced
        // motion (or no IO support) we simply leave them — no animation.
        if (reduce.matches || !('IntersectionObserver' in window)) return;

        const DURATION = 1100; // ms
        const easeOutExpo = (t: number): number =>
          t === 1 ? 1 : 1 - Math.pow(2, -10 * t);

        const countUp = (el: HTMLElement): void => {
          const to = Number(el.dataset.to ?? '0');
          if (!Number.isFinite(to) || to <= 0) return;
          const prefix = el.dataset.prefix ?? '';
          const suffix = el.dataset.suffix ?? '';
          const start = performance.now();
          const step = (now: number): void => {
            const p = Math.min((now - start) / DURATION, 1);
            const v = Math.round(to * easeOutExpo(p));
            el.textContent = `${prefix}${v}${suffix}`;
            if (p < 1) requestAnimationFrame(step);
            else el.textContent = `${prefix}${to}${suffix}`;
          };
          // seed at zero, then animate
          el.textContent = `${prefix}0${suffix}`;
          requestAnimationFrame(step);
        };

        let fired = false;
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting && !fired) {
                fired = true;
                nums.forEach(countUp);
                io.disconnect();
              }
            });
          },
          { threshold: 0.4 }
        );
        io.observe(strip);
      })();

      // ===== Build-your-stack composer (vanilla TS island) =====
      (() => {
        type StackOpt = { id: string; label: string; template: string; lang: string };
        type StackData = {
          frontend: StackOpt[];
          backend: StackOpt[];
          infra: StackOpt[];
          defaults: { frontend: string; backend: string; infra: string[] };
        };

        const root = document.getElementById('lp-stack');
        const screen = document.getElementById('lp-stack-screen');
        const dataEl = document.getElementById('lp-stack-data');
        const copyBtn = document.getElementById(
          'lp-stack-copy'
        ) as HTMLButtonElement | null;
        if (!root || !screen || !dataEl) return;

        let data: StackData;
        try {
          data = JSON.parse(dataEl.textContent ?? '') as StackData;
        } catch {
          return;
        }

        const sel = {
          frontend: data.defaults.frontend,
          backend: data.defaults.backend,
          infra: new Set<string>(data.defaults.infra),
        };

        type Seg = { t: string; c?: string };
        const lineFor = (opt: StackOpt, kind: 'fe' | 'be' | 'infra'): Seg[] => {
          if (kind === 'fe')
            return [
              { t: '$ ', c: 'lp-prompt' },
              { t: 're-shell create web ', c: 'lp-cmd' },
              { t: '--template ', c: 'lp-flag' },
              { t: opt.template, c: 'lp-str' },
            ];
          if (kind === 'be')
            return [
              { t: '$ ', c: 'lp-prompt' },
              { t: 're-shell generate service ', c: 'lp-cmd' },
              { t: '--template ', c: 'lp-flag' },
              { t: opt.template, c: 'lp-str' },
            ];
          return [
            { t: '$ ', c: 'lp-prompt' },
            { t: `re-shell ${opt.template} generate`, c: 'lp-cmd' },
          ];
        };

        const compose = (): Seg[][] => {
          const lines: Seg[][] = [];
          const fe = data.frontend.find((o) => o.id === sel.frontend);
          const be = data.backend.find((o) => o.id === sel.backend);
          if (fe) lines.push(lineFor(fe, 'fe'));
          if (be) lines.push(lineFor(be, 'be'));
          data.infra.forEach((o) => {
            if (sel.infra.has(o.id)) lines.push(lineFor(o, 'infra'));
          });
          if (lines.length === 0)
            lines.push([
              { t: '# pick a frontend or backend to compose a command', c: 'lp-mute' },
            ]);
          return lines;
        };

        const render = (): void => {
          const lines = compose();
          screen.textContent = '';
          lines.forEach((line, li) => {
            if (li > 0) screen.appendChild(document.createTextNode('\n'));
            line.forEach((s) => {
              if (s.c) {
                const span = document.createElement('span');
                span.className = s.c;
                span.textContent = s.t;
                screen.appendChild(span);
              } else {
                screen.appendChild(document.createTextNode(s.t));
              }
            });
          });
          // brief signal flash on update (reduced-motion-guarded in CSS)
          screen.classList.remove('lp-stack__screen--flash');
          void screen.offsetWidth;
          screen.classList.add('lp-stack__screen--flash');
          // refresh copy payload (plain text, no leading "$ ")
          if (copyBtn) {
            copyBtn.dataset.copy = lines
              .map((line) =>
                line
                  .map((s) => s.t)
                  .join('')
                  .replace(/^\$ /, '')
              )
              .join('\n');
            copyBtn.dataset.copied = 'false';
          }
        };

        const groups = Array.from(
          root.querySelectorAll<HTMLElement>('.lp-stack__group')
        );
        groups.forEach((group) => {
          const kind = group.dataset.group;
          const opts = Array.from(
            group.querySelectorAll<HTMLButtonElement>('.lp-stack__opt')
          );
          const isMulti = kind === 'infra';
          opts.forEach((btn) => {
            btn.addEventListener('click', () => {
              const value = btn.dataset.value ?? '';
              if (isMulti) {
                const on = btn.getAttribute('aria-checked') === 'true';
                btn.setAttribute('aria-checked', on ? 'false' : 'true');
                if (on) sel.infra.delete(value);
                else sel.infra.add(value);
              } else {
                opts.forEach((o) =>
                  o.setAttribute(
                    'aria-checked',
                    o === btn ? 'true' : 'false'
                  )
                );
                if (kind === 'frontend') sel.frontend = value;
                else if (kind === 'backend') sel.backend = value;
              }
              render();
            });
            // keyboard: arrows move within a radiogroup; space toggles checkbox
            btn.addEventListener('keydown', (ev: KeyboardEvent) => {
              if (!isMulti && (ev.key === 'ArrowRight' || ev.key === 'ArrowLeft')) {
                ev.preventDefault();
                const i = opts.indexOf(btn);
                const dir = ev.key === 'ArrowRight' ? 1 : -1;
                const next = opts[(i + dir + opts.length) % opts.length];
                next.focus();
                next.click();
              }
            });
          });
        });

        // render once to bind the copy payload (markup already matches default)
        render();

        copyBtn?.addEventListener('click', async () => {
          const text = copyBtn.dataset.copy ?? '';
          try {
            await navigator.clipboard.writeText(text);
            copyBtn.dataset.copied = 'true';
            window.setTimeout(() => (copyBtn.dataset.copied = 'false'), 1600);
          } catch {
            /* clipboard blocked — no-op */
          }
        });
      })();

      // ===== Hero depth parallax (subtle; reduced-motion-safe) =====
      (() => {
        if (reduce.matches) return;
        const browser = document.getElementById('lp-browser');
        if (!browser) return;
        let ticking = false;
        const onScroll = (): void => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const y = window.scrollY;
            // only drift while the hero is plausibly in view
            if (y < 900) {
              browser.style.transform = `translate3d(0, ${(y * -0.04).toFixed(
                2
              )}px, 0)`;
            }
            ticking = false;
          });
        };
        window.addEventListener('scroll', onScroll, { passive: true });
      })();

      // ===== Staggered scroll-reveal across sections =====
      const items = document.querySelectorAll<HTMLElement>('.lp-reveal');
      if (reduce.matches || !('IntersectionObserver' in window)) {
        items.forEach((el) => el.classList.add('is-in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                const el = e.target as HTMLElement;
                // stagger siblings that reveal together within one container
                const siblings = el.parentElement
                  ? Array.from(
                      el.parentElement.querySelectorAll<HTMLElement>(
                        ':scope > .lp-reveal'
                      )
                    )
                  : [el];
                const idx = Math.max(0, siblings.indexOf(el));
                el.style.transitionDelay = `${Math.min(idx, 6) * 70}ms`;
                el.classList.add('is-in');
                io.unobserve(el);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        items.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
