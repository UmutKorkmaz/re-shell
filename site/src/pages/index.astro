---
/**
 * Re-Shell — bespoke "dark mission-control" product landing page.
 *
 * A standalone Astro route that takes precedence over the Starlight content
 * collection for `/`. It reuses the dashboard token system (theme.css) and the
 * landing composition (landing.css), and shares the dark/light theme state with
 * the docs via the same `localStorage['starlight-theme']` key + `data-theme`.
 *
 * All facts/commands are real (CLI v0.29.2): 205 templates · 36 languages,
 * typed { ok, data, warnings } contract, 127.0.0.1-bound shell-free dashboard.
 */
import '../styles/theme.css';
import '../styles/landing.css';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const GITHUB = 'https://github.com/UmutKorkmaz/re-shell';
const NPM = 'https://www.npmjs.com/package/@re-shell/cli';
const docs = (slug: string) => `${base}/${slug}/`;

const trust = [
  { num: '205', label: 'framework templates', accent: true },
  { num: '36', label: 'languages' },
  { num: '171', label: 'frameworks' },
  { num: '127.0.0.1', label: 'local-only dashboard' },
] as const;

const features = [
  {
    title: 'One CLI, the whole stack',
    body: 'Module-Federation microfrontends (React, Vue, Svelte, Angular) and polyglot microservices, scaffolded and orchestrated from a single tool.',
    icon: 'rocket',
    chips: ['init', 'create', 'add', 'service'],
    span: 'wide',
    signal: true,
  },
  {
    title: '205 templates · 36 languages',
    body: 'A verified catalog spanning TypeScript, Python, Go, Rust, C#, Elixir, Zig and dozens more — inspectable before you scaffold.',
    icon: 'grid',
    chips: ['templates list', 'templates matrix'],
    span: 'tall',
  },
  {
    title: 'Hardened local dashboard',
    body: 'A token-authenticated, 127.0.0.1-bound, shell-free control surface. No remote exposure, no command injection.',
    icon: 'shield',
    chips: ['re-shell ui'],
  },
  {
    title: 'Typed JSON contract',
    body: 'Every data command emits a stable { ok, data, warnings } envelope — script Re-Shell without scraping terminal output.',
    icon: 'braces',
    chips: ['--json'],
  },
  {
    title: 'k8s · Helm · GitOps',
    body: 'Generate Kubernetes manifests, Helm charts, and GitOps pipelines straight from your workspace topology.',
    icon: 'cloud',
    chips: ['k8s', 'cloud', 'observe'],
  },
  {
    title: 'Extensible plugins',
    body: 'A first-class plugin system extends commands, templates, and generators — adapt the CLI to your platform.',
    icon: 'plug',
    chips: ['plugin', 'generate'],
  },
] as const;

const why = [
  {
    n: '01',
    h: 'No two-tool seam',
    p: 'Frontends and backends live in one workspace graph with one health model — not a microfrontend CLI bolted to an unrelated backend generator.',
  },
  {
    n: '02',
    h: 'Automation-first',
    p: 'The typed contract means CI, bots, and the dashboard all read the same envelope. Add --json to any data command and parse with confidence.',
  },
  {
    n: '03',
    h: 'Secure by construction',
    p: 'The dashboard binds to loopback, requires a token, and never shells out. Local control surface, zero remote attack surface.',
  },
  {
    n: '04',
    h: 'Real language breadth',
    p: '36 languages and 171 frameworks, each a maintained template with compatible database, cache, and deployment options.',
  },
  {
    n: '05',
    h: 'Health you can act on',
    p: 'doctor and workspace health surface dependency drift, version mismatches, and config issues — with optional auto-fix.',
  },
  {
    n: '06',
    h: 'Docs that match the build',
    p: 'This site is a third surface of @re-shell/ui — the same tokens, the same mission-control system as the dashboard.',
  },
] as const;

/** Inline stroke icons for the feature bento (no icon dependency). */
const ICONS: Record<string, string> = {
  rocket:
    '<path d="M5 15c-1.5 1-2 4-2 4s3-.5 4-2m6.5-8.5a8 8 0 0 1-6 6L4.5 14 3 9.5a8 8 0 0 1 6-6C13 1.5 17 2 19.5 2.5 20 5 20.5 9 18.5 13Z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/><circle cx="14.5" cy="8.5" r="1.4" stroke="currentColor" stroke-width="1.8" fill="none"/>',
  grid: '<rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8" fill="none"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8" fill="none"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8" fill="none"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.8" fill="none"/>',
  shield:
    '<path d="M12 3 4.5 6v5c0 4.5 3 7.8 7.5 10 4.5-2.2 7.5-5.5 7.5-10V6L12 3Z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  braces:
    '<path d="M8 4c-2 0-2 3-2 4s0 2-2 2c2 0 2 1 2 2s0 4 2 4M16 4c2 0 2 3 2 4s0 2 2 2c-2 0-2 1-2 2s0 4-2 4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
  cloud:
    '<path d="M7 18a4 4 0 0 1-.5-7.97 5 5 0 0 1 9.6-1.2A3.5 3.5 0 0 1 17 18H7Z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/>',
  plug: '<path d="M9 3v5M15 3v5M7 8h10v3a5 5 0 0 1-10 0V8ZM12 16v5" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>',
};
const icon = (name: string) => ICONS[name] ?? '';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Re-Shell — Microfrontends + microservices under one CLI</title>
    <meta
      name="description"
      content="Re-Shell unites microfrontends and polyglot microservices under one CLI: 205 framework templates across 36 languages, a hardened local dashboard, and a typed JSON contract."
    />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <meta name="theme-color" content="#0c0e12" />
    <meta property="og:title" content="Re-Shell" />
    <meta
      property="og:description"
      content="Microfrontends + polyglot microservices under one CLI. 205 templates, 36 languages, a hardened dashboard, and a typed JSON contract."
    />
    <meta property="og:type" content="website" />
    {/* Restore shared theme before paint (matches Starlight's storage key) */}
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('starlight-theme');
          const dark =
            t === 'dark' ||
            (!t && window.matchMedia('(prefers-color-scheme: dark)').matches) ||
            t === null;
          document.documentElement.dataset.theme = dark ? 'dark' : 'light';
          if (t === 'light') document.documentElement.dataset.theme = 'light';
        } catch (e) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
  </head>
  <body>
    <a class="lp-skip" href="#main">Skip to content</a>

    <!-- ============================= HEADER ============================= -->
    <header class="lp-header">
      <div class="lp-shell lp-header__inner">
        <a class="lp-brand" href={`${base}/`} aria-label="Re-Shell home">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path d="M12 2.5 21.5 12 12 21.5 2.5 12 12 2.5Z" fill="#c4f042" />
            <path d="M12 7.2 16.8 12 12 16.8 7.2 12 12 7.2Z" fill="#0c0e12" />
          </svg>
          Re-Shell
          <span class="lp-ver">v0.29.2</span>
        </a>
        <nav class="lp-nav" aria-label="Primary">
          <a class="lp-nav-hide" href="#features">Features</a>
          <a class="lp-nav-hide" href="#commands">Commands</a>
          <a class="lp-nav-hide" href={docs('roadmap')}>Roadmap</a>
          <a href={docs('getting-started/install')} class="lp-nav-cta"
            >Docs</a
          >
          <button
            class="lp-theme-toggle"
            type="button"
            id="lp-theme"
            aria-label="Toggle color theme"
          >
            <svg
              class="lp-icon-moon"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"
                stroke-linejoin="round"></path>
            </svg>
            <svg
              class="lp-icon-sun"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4"></circle>
              <path
                d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
                stroke-linecap="round"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main id="main">
      <!-- ============================= HERO ============================= -->
      <section class="lp-hero">
        <div class="lp-shell lp-hero__grid">
          <div class="lp-hero__copy lp-reveal">
            <span class="lp-eyebrow">Full-stack platform CLI</span>
            <h1 class="lp-h1">
              Microfrontends and microservices,<br />
              <span class="lp-accent">one mission-control CLI.</span>
            </h1>
            <p class="lp-sub">
              Re-Shell unifies Module-Federation microfrontends and polyglot
              microservices under a single tool — 205 framework templates across
              36 languages, a hardened local dashboard, and a stable typed JSON
              contract for automation.
            </p>

            <div class="lp-install" id="lp-install">
              <code
                ><span class="lp-prompt">$</span
                ><span id="lp-install-cmd"
                  >npm i -g @re-shell/cli</span
                ></code
              >
              <button
                class="lp-copy"
                type="button"
                data-copy="npm i -g @re-shell/cli"
                aria-label="Copy install command"
              >
                <svg
                  class="lp-icon-copy"
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                  ><rect x="9" y="9" width="11" height="11" rx="2"></rect><path
                    d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg
                >
                <svg
                  class="lp-icon-check"
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                  ><path d="M5 13l4 4L19 7" stroke-linecap="round"
                    stroke-linejoin="round"></path></svg
                >
              </button>
            </div>

            <div class="lp-actions">
              <a class="lp-btn lp-btn--primary" href={docs('getting-started/install')}>
                Get started
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                  ><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round"
                    stroke-linejoin="round"></path></svg
                >
              </a>
              <a class="lp-btn lp-btn--ghost" href={GITHUB} rel="noopener">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                  ><path
                    d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11 11 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"
                  ></path></svg
                >
                View on GitHub
              </a>
            </div>

            <dl class="lp-trust">
              {
                trust.map((t) => (
                  <div class="lp-trust__item">
                    <dt class={`lp-trust__num${t.accent ? ' lp-accent' : ''}`}>
                      {t.num}
                    </dt>
                    <dd class="lp-trust__label" style="margin:0">
                      {t.label}
                    </dd>
                  </div>
                ))
              }
            </dl>
          </div>

          <!-- ===== DASHBOARD RECREATION (hero visual) ===== -->
          <div class="lp-window lp-reveal" role="img"
            aria-label="Re-Shell dashboard: sidebar with active Overview nav, a bento of workspace, health, and jobs tiles, and a terminal block.">
            <div class="lp-win-bar">
              <span class="lp-dot lp-dot--r"></span>
              <span class="lp-dot lp-dot--y"></span>
              <span class="lp-dot lp-dot--g"></span>
              <span class="lp-win-path">re-shell ui · 127.0.0.1:3333</span>
              <span class="lp-win-live"
                ><span class="lp-live-dot"></span>live</span
              >
            </div>
            <div class="lp-win-body">
              <aside class="lp-win-side" aria-hidden="true">
                <span class="lp-side-grp">Control</span>
                <span class="lp-side-item lp-side-item--active"
                  ><span class="lp-mark">◆</span>Overview</span
                >
                <span class="lp-side-item"
                  ><span class="lp-mark">◇</span>Workspace</span
                >
                <span class="lp-side-item"
                  ><span class="lp-mark">◇</span>Templates</span
                >
                <span class="lp-side-item"
                  ><span class="lp-mark">◇</span>Jobs</span
                >
                <span class="lp-side-item"
                  ><span class="lp-mark">◇</span>Health</span
                >
                <span class="lp-side-grp">System</span>
                <span class="lp-side-item"
                  ><span class="lp-mark">◇</span>Settings</span
                >
              </aside>
              <div class="lp-win-main" aria-hidden="true">
                <div class="lp-tile lp-tile--hero">
                  <div>
                    <div class="lp-tile__label">Workspaces</div>
                    <div class="lp-tile__metric">
                      12<span class="lp-accent"> ✓</span>
                    </div>
                    <div class="lp-tile__sub">8 apps · 4 services · synced</div>
                  </div>
                  <div class="lp-spark">
                    <span style="height:40%"></span>
                    <span style="height:55%"></span>
                    <span style="height:48%"></span>
                    <span style="height:70%"></span>
                    <span style="height:62%"></span>
                    <span style="height:85%"></span>
                    <span style="height:100%"></span>
                  </div>
                </div>
                <div class="lp-tile">
                  <div class="lp-tile__label">Health</div>
                  <div style="margin-top:.5rem">
                    <span class="lp-badge lp-badge--healthy"
                      ><i></i>Healthy</span
                    >
                  </div>
                  <div class="lp-tile__sub">36/36 checks</div>
                </div>
                <div class="lp-tile">
                  <div class="lp-tile__label">Drift</div>
                  <div style="margin-top:.5rem">
                    <span class="lp-badge lp-badge--warn"><i></i>2 warn</span>
                  </div>
                  <div class="lp-tile__sub">deps · 1 minor</div>
                </div>
                <div class="lp-tile lp-jobs">
                  <div class="lp-tile__label" style="margin-bottom:.3rem">
                    Recent jobs
                  </div>
                  <div class="lp-job-row">
                    <span class="lp-badge lp-badge--healthy"><i></i>ok</span>
                    <span class="lp-job-id">build · web-shell</span>
                    <span class="lp-job-dur">4.2s</span>
                  </div>
                  <div class="lp-job-row">
                    <span class="lp-badge lp-badge--healthy"><i></i>ok</span>
                    <span class="lp-job-id">generate · api</span>
                    <span class="lp-job-dur">1.1s</span>
                  </div>
                  <div class="lp-job-row">
                    <span class="lp-badge lp-badge--info"><i></i>run</span>
                    <span class="lp-job-id">doctor --fix</span>
                    <span class="lp-job-dur">…</span>
                  </div>
                </div>
                <div class="lp-mini-term">
                  <div>
                    <span class="lp-prompt">$</span> re-shell workspace summary
                    <span class="lp-mute">--json</span>
                  </div>
                  <div><span class="lp-mute">{`{ "ok": `}</span><span
                      class="lp-ok">true</span
                    ><span class="lp-mute">{`, "data": { … } }`}</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================ FEATURES ============================ -->
      <section class="lp-section" id="features">
        <div class="lp-shell">
          <div class="lp-section__head lp-reveal">
            <span class="lp-eyebrow">What you get</span>
            <h2 class="lp-h2">A full-stack platform, not a pile of scripts.</h2>
            <p>
              Every Re-Shell surface — CLI, dashboard, and contract — is built on
              the same workspace model. Here is what that buys you.
            </p>
          </div>
          <div class="lp-bento lp-stagger">
            {
              features.map((f, i) => (
                <article
                  class={`lp-bento__cell lp-reveal${
                    f.span === 'wide' ? ' lp-bento__cell--wide' : ''
                  }${f.span === 'tall' ? ' lp-bento__cell--tall' : ''}${
                    f.signal ? ' lp-bento__cell--signal' : ''
                  }`}
                  style={`--i:${i}`}
                >
                  <span class="lp-bento__icon" aria-hidden="true">
                    <svg
                      class="lp-bento__icon-svg"
                      viewBox="0 0 24 24"
                      width="24"
                      height="24"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      set:html={icon(f.icon)}
                    />
                  </span>
                  <h3 class="lp-bento__title">{f.title}</h3>
                  <p class="lp-bento__body">{f.body}</p>
                  <div class="lp-chiprow">
                    {f.chips.map((c) => (
                      <span class="lp-chip">{c}</span>
                    ))}
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ========================= COMMAND TOUR ========================= -->
      <section class="lp-section" id="commands">
        <div class="lp-shell">
          <div class="lp-section__head lp-reveal">
            <span class="lp-eyebrow">Command tour</span>
            <h2 class="lp-h2">Real commands, real output.</h2>
            <p>
              Inspect your workspace, browse the catalog, run health checks, and
              launch the dashboard. Data commands speak the typed envelope.
            </p>
          </div>
          <div class="lp-tour">
            <div class="lp-term lp-reveal">
              <div class="lp-term__bar">
                <span class="lp-dot lp-dot--r"></span>
                <span class="lp-dot lp-dot--y"></span>
                <span class="lp-dot lp-dot--g"></span>
                <span class="lp-term__title">workspace summary --json</span>
              </div>
<pre class="lp-term__body"><span class="lp-prompt">$</span> <span class="lp-cmd">re-shell workspace summary</span> <span class="lp-flag">--json</span>
<span class="lp-mute">{`{`}</span>
  <span class="lp-key">"ok"</span>: <span class="lp-ok">true</span>,
  <span class="lp-key">"data"</span>: <span class="lp-mute">{`{`}</span>
    <span class="lp-key">"root"</span>: <span class="lp-str">"./acme-platform"</span>,
    <span class="lp-key">"packageManager"</span>: <span class="lp-str">"pnpm"</span>,
    <span class="lp-key">"workspaces"</span>: <span class="lp-ok">12</span>,
    <span class="lp-key">"graph"</span>: <span class="lp-mute">{`{ "nodes": 12, "edges": 19 }`}</span>,
    <span class="lp-key">"health"</span>: <span class="lp-str">"healthy"</span>
  <span class="lp-mute">{`}`}</span>,
  <span class="lp-key">"warnings"</span>: <span class="lp-mute">[]</span>
<span class="lp-mute">{`}`}</span></pre>
            </div>

            <div class="lp-term lp-reveal">
              <div class="lp-term__bar">
                <span class="lp-dot lp-dot--r"></span>
                <span class="lp-dot lp-dot--y"></span>
                <span class="lp-dot lp-dot--g"></span>
                <span class="lp-term__title">templates list</span>
              </div>
<pre class="lp-term__body"><span class="lp-prompt">$</span> <span class="lp-cmd">re-shell templates list</span>
<span class="lp-mute">📋 Templates (</span><span class="lp-ok">205</span><span class="lp-mute">)</span>

  <span class="lp-str">●</span> express   <span class="lp-mute">[typescript]</span> minimalist Node.js web framework
  <span class="lp-str">●</span> fastify   <span class="lp-mute">[typescript]</span> fast, schema-based validation
  <span class="lp-str">●</span> actix-web <span class="lp-mute">[rust]</span>       high-performance async web
  <span class="lp-str">●</span> fiber     <span class="lp-mute">[go]</span>         express-style router
  <span class="lp-str">●</span> phoenix   <span class="lp-mute">[elixir]</span>     real-time, fault-tolerant
  <span class="lp-mute">… 36 languages · 171 frameworks</span></pre>
            </div>

            <div class="lp-term lp-reveal">
              <div class="lp-term__bar">
                <span class="lp-dot lp-dot--r"></span>
                <span class="lp-dot lp-dot--y"></span>
                <span class="lp-dot lp-dot--g"></span>
                <span class="lp-term__title">doctor</span>
              </div>
<pre class="lp-term__body"><span class="lp-prompt">$</span> <span class="lp-cmd">re-shell doctor</span>
<span class="lp-ok">✓</span> workspace config valid
<span class="lp-ok">✓</span> package manager resolved <span class="lp-mute">(pnpm)</span>
<span class="lp-ok">✓</span> dependency graph acyclic
<span class="lp-warn">!</span> 1 minor version drift <span class="lp-mute">(run --fix)</span>
<span class="lp-ok">✓</span> 36 / 36 health checks passed

<span class="lp-mute">Run with</span> <span class="lp-flag">--fix</span> <span class="lp-mute">to apply safe repairs.</span></pre>
            </div>

            <div class="lp-term lp-reveal">
              <div class="lp-term__bar">
                <span class="lp-dot lp-dot--r"></span>
                <span class="lp-dot lp-dot--y"></span>
                <span class="lp-dot lp-dot--g"></span>
                <span class="lp-term__title">ui</span>
              </div>
