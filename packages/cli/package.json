{
  "name": "@re-shell/cli",
  "version": "0.30.1",
  "description": "Full-stack development platform uniting microservices and microfrontends. Build complete applications with .NET (ASP.NET Core Web API, Minimal API), Java (Spring Boot, Quarkus, Micronaut, Vert.x), Rust (Actix-Web, Warp, Rocket, Axum), Python (FastAPI, Django, Flask) and Node.js backends alongside React, Vue, Svelte frontends - all managed through one powerful CLI",
  "main": "dist/index.js",
  "files": [
    "dist/**/*",
    "examples/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "EXAMPLES.md"
  ],
  "bin": {
    "re-shell": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/utils/schemas && cp src/schemas/workspace-v2.schema.json dist/utils/schemas/re-shell-workspace.schema.json && mkdir -p dist/completions && cp src/completions/bash dist/completions/bash && cp src/completions/zsh dist/completions/zsh",
    "bundle:dashboard": "node scripts/bundle-dashboard.mjs",
    "build:dist": "npm run build && npm run bundle:dashboard",
    "dev": "tsc --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --config vitest.coverage.config.ts",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:plan": "node tests/run-cli-plan.mjs --suite=all",
    "lint": "eslint src --ext ts",
    "clean": "rimraf dist",
    "prepublishOnly": "rimraf dist && npm run build && npm run bundle:dashboard"
  },
  "keywords": [
    "microfrontend",
    "react",
    "re-shell",
    "cli",
    "framework",
    "micro-frontend",
    "monorepo",
    "bundle-analysis",
    "health-check",
    "cicd",
    "code-generation",
    "performance",
    "security",
    "migration-tools"
  ],
  "author": "Umut Korkmaz",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/UmutKorkmaz/re-shell.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/UmutKorkmaz/re-shell/issues"
  },
  "homepage": "https://umutkorkmaz.github.io/re-shell/",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.31",
    "@re-shell/contracts": "workspace:^",
    "boxen": "^8.0.1",
    "chalk": "^4.1.2",
    "chokidar": "^4.0.3",
    "cli-table3": "^0.6.5",
    "commander": "^11.0.0",
    "cosmiconfig": "^9.0.0",
    "dayjs": "^1.11.13",
    "dockerode": "^4.0.7",
    "dotenv": "^16.6.0",
    "ejs": "^3.1.10",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.0.0",
    "glob": "^10.4.5",
    "handlebars": "^4.7.8",
    "ink": "^6.6.0",
    "ink-spinner": "^5.0.0",
    "inquirer": "^8.2.7",
    "js-yaml": "^4.1.1",
    "ora": "^5.4.1",
    "prompts": "^2.0.0",
    "react": "^19.2.3",
    "semver": "^7.7.2",
    "simple-git": "^3.32.3",
    "yaml": "^2.3.2",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.17.46",
    "@types/prompts": "^2.0.0",
    "@types/semver": "^7.7.0",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^0.34.6",
    "globby": "^16.1.0",
    "ink-testing-library": "4",
    "lodash": "^4.17.21",
    "node-pty": "1.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "uuid": "^9.0.0",
    "vite": "^4.5.14",
    "vitest": "^0.34.3",
    "zod": "^4.4.3"
  }
}
